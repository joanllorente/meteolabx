# Copy the required names into Railway Variables or a local, ignored .env.
# Never commit real values.

METEOLABX_AEMET_API_KEY=
METEOLABX_METEOCAT_API_KEY=
METEOLABX_METEOFRANCE_API_KEY=
METEOLABX_METOFFICE_API_KEY=
METEOLABX_WINDY_API_KEY=
METEOLABX_NETATMO_CLIENT_ID=
METEOLABX_NETATMO_CLIENT_SECRET=
METEOLABX_NETATMO_REFRESH_TOKEN=
METEOLABX_FROST_CLIENT_ID=
METEOLABX_FROST_CLIENT_SECRET=

# Euskalmet: use a pre-generated JWT, or configure a private key path.
METEOLABX_EUSKALMET_JWT=
METEOLABX_EUSKALMET_API_KEY=
METEOLABX_EUSKALMET_PRIVATE_KEY_PATH=
METEOLABX_EUSKALMET_JWT_ISS=meteolabx
METEOLABX_EUSKALMET_JWT_EMAIL=

# POEM authentication is optional depending on the selected endpoint.
METEOLABX_POEM_BEARER_TOKEN=
METEOLABX_POEM_API_KEY=
METEOLABX_POEM_BASIC_USER=
METEOLABX_POEM_BASIC_PASSWORD=

METEOLABX_CORS_ORIGINS=https://meteolabx.com
