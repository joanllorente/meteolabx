{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "server.main:app", "--port", "8000", "--loop", "asyncio"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "streamlit", "run", "meteolabx.py", "--server.port", "8501", "--server.headless", "true"],
      "port": 8501
    }
  ]
}
